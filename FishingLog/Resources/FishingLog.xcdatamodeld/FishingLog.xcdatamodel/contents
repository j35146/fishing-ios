        <attribute name="spotDescription" optional="YES" attributeType="String"/>
        <attribute name="latitude"  optional="YES" attributeType="Double" defaultValueString="0" usesScalarValueType="YES"/>
        <attribute name="longitude" optional="YES" attributeType="Double" defaultValueString="0" usesScalarValueType="YES"/>
        <attribute name="spotType"  optional="YES" attributeType="String"/>
        <attribute name="isPublic"  optional="YES" attributeType="Boolean" defaultValueString="YES" usesScalarValueType="YES"/>
        <attribute name="photoUrl"  optional="YES" attributeType="String"/>
        <attribute name="createdAt" optional="YES" attributeType="Date" usesScalarValueType="NO"/>
    </entity>

</model>
