    <!-- StyleEntity -->
    <entity name="StyleEntity" representedClassName="StyleEntity" syncable="YES" codeGenerationType="class">
        <attribute name="id"   optional="NO"  attributeType="Integer 16" usesScalarValueType="YES"/>
