    <!-- MediaEntity（Phase 2 新增） -->
    <entity name="MediaEntity" representedClassName="MediaEntity" syncable="YES" codeGenerationType="class">
        <attribute name="id"         optional="NO"  attributeType="String"/>
        <attribute name="localId"    optional="YES" attributeType="UUID"/>
        <attribute name="tripId"     optional="YES" attributeType="String"/>
        <attribute name="tripLocalId" optional="YES" attributeType="UUID"/>
        <attribute name="key"        optional="YES" attributeType="String"/>
        <attribute name="url"        optional="YES" attributeType="String"/>
        <attribute name="type"       optional="YES" attributeType="String"/>
        <attribute name="syncStatus" optional="YES" attributeType="String" defaultValueString="pending"/>
        <attribute name="createdAt"  optional="YES" attributeType="Date" usesScalarValueType="NO"/>
